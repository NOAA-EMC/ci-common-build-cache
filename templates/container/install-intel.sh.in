#!/bin/bash
set -e

# Download the key to system keyring
wget -O- https://apt.repos.intel.com/intel-gpg-keys/GPG-PUB-KEY-INTEL-SW-PRODUCTS.PUB \
| gpg --dearmor | sudo tee /usr/share/keyrings/oneapi-archive-keyring.gpg > /dev/null

# Add signed entry to apt sources and configure the APT client to use Intel repository:
echo "deb [signed-by=/usr/share/keyrings/oneapi-archive-keyring.gpg] https://apt.repos.intel.com/oneapi all main" | sudo tee /etc/apt/sources.list.d/oneAPI.list

sudo apt-get update

if [[ "@COMPILER@" == "classic" ]]; then
  # Install Intel Classic compilers (@COMPILER_VERSION@)
  _ver="@COMPILER_VERSION@"
  COMP_PKG_VERSION=$(apt-cache madison intel-oneapi-compiler-dpcpp-cpp-and-cpp-classic | awk '{ print $3 }' | grep "^${_ver//./\\.}" | head -1)
  sudo apt-get install -y "intel-oneapi-compiler-dpcpp-cpp-and-cpp-classic=${COMP_PKG_VERSION}"
elif [[ "@COMPILER@" == "oneapi" ]]; then
  # Install Intel OneAPI compilers (@COMPILER_VERSION@)
  _ver="@COMPILER_VERSION@"
  COMP_PKG_VERSION=$(apt-cache madison intel-oneapi-compiler-dpcpp-cpp | awk '{ print $3 }' | grep "^${_ver//./\\.}" | head -1)
  sudo apt-get install -y "intel-oneapi-compiler-dpcpp-cpp=${COMP_PKG_VERSION}" "intel-oneapi-compiler-fortran=${COMP_PKG_VERSION}"
fi

if [[ "@MPI@" == "intel-oneapi-mpi" ]]; then
  # Install Intel MPI (@MPI_VERSION@)
  _ver="@MPI_VERSION@"
  MPI_PKG_VERSION=$(apt-cache madison intel-oneapi-mpi-devel | awk '{ print $3 }' | grep "^${_ver//./\\.}" | head -1)
  sudo apt-get install -y "intel-oneapi-mpi-devel=${MPI_PKG_VERSION}"
fi
