#!/bin/bash
set -e

# Download the key to system keyring
wget -O- https://apt.repos.intel.com/intel-gpg-keys/GPG-PUB-KEY-INTEL-SW-PRODUCTS.PUB \
| gpg --dearmor | tee /usr/share/keyrings/oneapi-archive-keyring.gpg > /dev/null

# Add signed entry to apt sources and configure the APT client to use Intel repository:
echo "deb [signed-by=/usr/share/keyrings/oneapi-archive-keyring.gpg] https://apt.repos.intel.com/oneapi all main" | tee /etc/apt/sources.list.d/oneAPI.list

apt-get update

compiler_version="@COMPILER_VERSION@"
mpi_version="@MPI_VERSION@"
packages=()

if [[ "@COMPILER@" == "classic" ]]; then
  packages+=("intel-oneapi-compiler-dpcpp-cpp-and-cpp-classic-${compiler_version}")
  packages+=("intel-oneapi-compiler-fortran-${compiler_version}")
elif [[ "@COMPILER@" == "oneapi" ]]; then
  packages+=("intel-oneapi-compiler-dpcpp-cpp-${compiler_version}")
  packages+=("intel-oneapi-compiler-fortran-${compiler_version}")
fi

if [[ "@MPI@" == "intel-oneapi-mpi" ]]; then
  packages+=("intel-oneapi-mpi-devel=${mpi_version}")
fi

if ((${#packages[@]} > 0)); then
  apt-get install -y "${packages[@]}"
fi
